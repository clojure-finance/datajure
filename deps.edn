{:paths ["src" "resources"]
 :deps {techascent/tech.ml.dataset {:mvn/version "8.007"}
        ;; charred is the JSON/CSV parser tech.ml.dataset already uses; declared
        ;; explicitly because datajure.io requires charred.api directly for JSON Lines.
        com.cnuernber/charred {:mvn/version "1.038"}
        org.clojure/clojure {:mvn/version "1.12.4"}}
 :aliases
 {:nrepl
  {:extra-deps {nrepl/nrepl {:mvn/version "1.7.0"}}
   :main-opts ["-m" "nrepl.cmdline" "--port" "7888"]
   :extra-paths ["test"]}
  :clerk
  {:extra-deps {io.github.nextjournal/clerk {:mvn/version "0.18.1158"}}
   :extra-paths ["notebooks"]}
  :clay
  {:extra-deps {org.scicloj/clay {:mvn/version "2.0.11"}}
   :extra-paths ["notebooks"]}
  :build
  {:deps {io.github.clojure/tools.build {:mvn/version "0.10.10"}
          slipset/deps-deploy {:mvn/version "0.2.2"}}
   :ns-default build}}}
